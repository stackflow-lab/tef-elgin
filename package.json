{
  "name": "@stackflowlab/elgin-sdk",
  "version": "0.0.1",
  "description": "SDK Node.js para integração com Elgin TEF - Terminal de pagamentos eletrônicos",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "playground": "tsx playground/index.ts",
    "playground:debug": "tsx playground/debug-example.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "os": [
    "win32"
  ],
  "keywords": [
    "elgin",
    "tef",
    "payment",
    "pagamento",
    "pos",
    "terminal",
    "pinpad",
    "pix",
    "credit-card",
    "debit-card",
    "sdk",
    "typescript"
  ],
  "author": "StackFlowLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stackflowlab/elgin-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/stackflowlab/elgin-sdk/issues"
  },
  "homepage": "https://github.com/stackflowlab/elgin-sdk#readme",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "koffi": "^2.15.2"
  }
}
